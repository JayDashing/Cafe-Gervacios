{
  "project": "Cafe Gervacios Refined Premium Fixed Top-View Operational Restaurant System",
  "camera": {
    "name": "Camera_Fixed_2_5D_Operations",
    "type": "ORTHOGRAPHIC",
    "recommended_render_angle": "fixed angled top view, roughly 52 degrees down from horizon with orthographic projection",
    "controls": {
      "rotate": false,
      "pan": false,
      "orbit": false,
      "limited_zoom": true
    },
    "threejs_controls_note": "Use the exported fixed camera. Do not attach free OrbitControls. If zoom is enabled, clamp min/max tightly."
  },
