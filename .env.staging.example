APP_NAME="Cafe Gervacios"
APP_VENUE_NAME="Cafe Gervacios"
APP_ENV=staging
APP_KEY=base64:REPLACE_ME
APP_DEBUG=true
APP_TIMEZONE=Asia/Manila
APP_URL=https://staging.example.com

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=REPLACE_ME
DB_PORT=3306
DB_DATABASE=REPLACE_ME
DB_USERNAME=REPLACE_ME
DB_PASSWORD=REPLACE_ME

CACHE_STORE=database
SESSION_DRIVER=database
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SESSION_DOMAIN=null
QUEUE_CONNECTION=database
FILESYSTEM_DISK=public

MAIL_MAILER=log
MAIL_FROM_ADDRESS="staging@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Staging must use PayMongo test mode only.
PAYMONGO_MODE=test
PAYMONGO_ALLOW_LIVE=false
PAYMONGO_PUBLIC_KEY=pk_test_REPLACE_ME
PAYMONGO_SECRET_KEY=sk_test_REPLACE_ME
PAYMONGO_WEBHOOK_SECRET=whsec_test_REPLACE_ME
PAYMONGO_WEBHOOK_TOLERANCE_SECONDS=300

# Optional integrations for staging.
SEMAPHORE_API_KEY=
SEMAPHORE_SENDER_NAME=CafeGervacios
FB_PAGE_ID=
FB_ACCESS_TOKEN=
SUPERADMIN_EMAILS=owner@example.test
VITE_APP_NAME="${APP_NAME}"

OCCUPANCY_DURATION_MINUTES=90
RESERVATION_MAX_PARTY_FALLBACK=4
RESERVATION_HOLD_WINDOW_HOURS=5
AUTOMATION_QUEUE_HOLD_MINUTES=5
PEAK_HOURS_LEARN_FROM_QUEUE=true
