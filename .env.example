APP_NAME="Cafe Gervacios"
APP_VENUE_NAME="Cafe Gervacios"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Manila
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cafe_gervacios_kiosk
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync
CACHE_STORE=file
CACHE_PREFIX=

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="testing@example.test"
MAIL_FROM_NAME="${APP_NAME}"

# PayMongo test mode only. Never put live keys in local or staging env files.
PAYMONGO_MODE=test
PAYMONGO_ALLOW_LIVE=false
PAYMONGO_PUBLIC_KEY=pk_test_REPLACE_ME
PAYMONGO_SECRET_KEY=sk_test_REPLACE_ME
PAYMONGO_WEBHOOK_SECRET=whsec_test_REPLACE_ME
PAYMONGO_WEBHOOK_TOLERANCE_SECONDS=300

# Semaphore SMS testing. Leave blank to skip SMS sends and log warnings.
SEMAPHORE_API_KEY=
SEMAPHORE_SENDER_NAME=CafeGervacios

# Facebook sync testing. Leave blank unless testing the scheduled sync.
FB_PAGE_ID=
FB_ACCESS_TOKEN=

SUPERADMIN_EMAILS=owner@example.test
VITE_APP_NAME="${APP_NAME}"

# Venue operations
OCCUPANCY_DURATION_MINUTES=90
RESERVATION_MAX_PARTY_FALLBACK=4
RESERVATION_HOLD_WINDOW_HOURS=5
AUTOMATION_QUEUE_HOLD_MINUTES=5
PEAK_HOURS_LEARN_FROM_QUEUE=true
